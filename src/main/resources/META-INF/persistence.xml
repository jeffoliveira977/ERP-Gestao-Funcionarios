<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="gestao-funcionarios-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.erp.gestaofuncionarios.model.Department</class>
        <class>com.erp.gestaofuncionarios.model.Position</class>
        <class>com.erp.gestaofuncionarios.model.Employee</class>
        <class>com.erp.gestaofuncionarios.model.TimeRecord</class>
        <class>com.erp.gestaofuncionarios.model.Payroll</class>
        <class>com.erp.gestaofuncionarios.model.Vacation</class>
        <class>com.erp.gestaofuncionarios.model.Benefit</class>
        <class>com.erp.gestaofuncionarios.model.EmployeeBenefit</class>
        <class>com.erp.gestaofuncionarios.model.TrainingRecord</class>
        <class>com.erp.gestaofuncionarios.model.UserAccount</class>
        <class>com.erp.gestaofuncionarios.model.Absence</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/gestao_funcionarios"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="postgres"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="jakarta.persistence.schema-generation.database.action" value="update"/>
        </properties>
    </persistence-unit>
</persistence>
